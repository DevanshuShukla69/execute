# Frontend Environment Variables (set in Vercel dashboard → Settings → Environment Variables)
# ──────────────────────────────────────────────────────────────────────────────

# Backend API URL — your Railway backend deployment URL
# This is baked into the React build at compile time.
# For local dev, leave empty (the proxy in package.json handles it).
# For Vercel, set this to your Railway backend URL.
REACT_APP_API_URL=https://your-railway-backend.up.railway.app
